{
  "entities": {
    "visitorLog": {
      "title": "Visitor Log",
      "description": "A record of a library visit.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the visitor." },
        "email": { "type": "string", "format": "email", "description": "Email address of the visitor." },
        "role": { "type": "string", "enum": ["Student", "Faculty", "Employee"], "description": "Role of the visitor." },
        "college": { "type": "string", "description": "College or department of the visitor." },
        "reason": { "type": "string", "description": "Reason for the visit." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Date and time of the visit." },
        "employeeType": { "type": "string", "enum": ["Teacher", "Staff"], "description": "Type of employee (if applicable)." }
      },
      "required": ["fullName", "email", "role", "college", "reason", "timestamp"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "role": { "type": "string", "enum": ["Admin", "User"], "description": "Role of the user." }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/visitorLogs/{logId}": {
      "schema": "visitorLog",
      "description": "Collection of visitor logs."
    },
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "Collection of user profiles for RBAC."
    }
  }
}
