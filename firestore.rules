rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - email: string (required, email format)
    //   - role: string (required, enum: ['Admin', 'User'])
    //
    // Collection: visitorLogs
    // Document ID: {logId} (Auto-generated)
    // Fields:
    //   - fullName: string (required, 1-100 chars)
    //   - email: string (required, email format, must match auth email)
    //   - role: string (required, enum: ['Student', 'Faculty', 'Employee'])
    //   - college: string (required, 1-100 chars)
    //   - reason: string (required, 1-100 chars)
    //   - timestamp: timestamp (required)
    //   - employeeType: string (optional, enum: ['Teacher', 'Staff'])
    //
    // ===============================================================

    // Collection: blockedEmails
    // Document ID: {email} (Lowercase email address)
    // Fields:
    //   - email: string (required, email format)
    //   - blockedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
        (request.auth.token.email == "ranezetvhon.bachiller@neu.edu.ph" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "jcesperanza@neu.edu.ph" && request.auth.token.email_verified == true)
      );
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[a-zA-Z0-9._%+-]+@neu\\.edu\\.ph$");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isNotBlocked(email) {
      return !exists(/databases/$(database)/documents/blockedEmails/$(email));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'role']) &&
             isValidEmail(data.email) &&
             data.role in ['Admin', 'User'];
    }

    function isValidVisitorLog(data) {
      return hasOnlyAllowedFields(['fullName', 'email', 'role', 'college', 'reason', 'timestamp', 'employeeType']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.email is string && data.email.matches("^[a-zA-Z0-9._%+-]+@neu\\.edu\\.ph$") &&
             data.role in ['Student', 'Faculty', 'Employee'] &&
             data.college is string && data.college.size() > 0 && data.college.size() <= 100 &&
             data.reason is string && data.reason.size() > 0 && data.reason.size() <= 100 &&
             data.timestamp is timestamp &&
             (!('employeeType' in data) || data.employeeType in ['Teacher', 'Staff']) &&
             isNotBlocked(data.email);
    }

    function isValidBlockedEmail(data) {
      return hasOnlyAllowedFields(['email', 'blockedAt']) &&
             data.email is string && data.email.size() > 0 &&
             data.blockedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow users to create their own profile with 'User' role, or 'Admin' if they are special accounts
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (
        request.resource.data.role == 'User' || 
        (request.resource.data.role == 'Admin' && (
          request.auth.token.email == "ranezetvhon.bachiller@neu.edu.ph" || 
          request.auth.token.email == "jcesperanza@neu.edu.ph"
        ))
      );
      
      // Only admins can update roles
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /visitorLogs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email);
      
      // Allow anyone to create a visitor log
      allow create: if isValidVisitorLog(request.resource.data);
      
      // Logs are immutable
      allow update, delete: if false;
    }

    match /blockedEmails/{email} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin() && isValidBlockedEmail(request.resource.data);
    }
  }
}
